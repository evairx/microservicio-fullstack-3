---
const { id } = Astro.params;
import Layout from '../../layouts/main.astro';

import { IconArrowNarrowLeft } from '@tabler/icons-preact';

import Aside from '../../components/aside.astro';
import { ViewImage } from '../../components/view-image';
import PostDetail from '../../components/posts/post-detail.astro';
---

<Layout title="Inicio — Pterodactweet | La red social de los dinosaurios">
    <main class="bg-[#131313] min-h-screen">
        <div class="relative flex justify-center w-full max-w-[1200px] mx-auto min-h-screen">
            <Aside server:defer/>

            <section class="bg-[#181818] w-full max-w-[550px] min-h-screen border-x border-white/5 px-3 pb-20">
                
                <header class="w-full flex items-center pt-6 px-2 gap-5">
                    <a href="/">
                        <button class="flex gap-3 items-center justify-center cursor-pointer hover:scale-[.95] hover:opacity-80 transition-transform duration-200 shadow-sm">
                            <IconArrowNarrowLeft class="w-[32px] h-[32px] text-white" />
                            <p class="text-white text-[1.25rem] font-medium">Volver</p>
                        </button>
                    </a>
                </header>

                <div class="mt-8 px-2 flex flex-col gap-6">
                    <PostDetail id={id} server:defer>
                        <p slot="fallback">cargando...</p>
                    </PostDetail>
                </div>
            </section>
        </div>
    </main>
    <ViewImage client:only/>
</Layout>